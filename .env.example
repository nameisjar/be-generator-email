# ===== Server =====
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ===== Database =====
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_alias_manager?schema=public

# ===== JWT =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-random-hex-string
JWT_REFRESH_SECRET=replace-with-another-random-hex-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=14d

# ===== Email Routing =====
# The domain that aliases belong to (e.g. algonova.my.id)
MAIL_DOMAINS=name@domain1.id,name@domain2.id
# MAIL_DOMAIN=name@domain.id
# Shared secret for HMAC signature verification on the webhook endpoint
# Must match the one configured in the Cloudflare Worker
WEBHOOK_SECRET=replace-with-shared-secret
# How old (in seconds) a webhook request can be before we reject it (replay protection)
WEBHOOK_MAX_AGE_SECONDS=300

# ===== Google OAuth (optional) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ===== Cookies =====
# 'lax' (default) for same-site setups, e.g. app.algonova.my.id + email.algonova.my.id
#       (both share the algonova.my.id parent domain — recommended)
# 'none' for cross-origin (e.g. Vercel *.vercel.app + email.algonova.my.id).
# When 'none' is used, Secure is forced on, so backend MUST be served over HTTPS.
COOKIE_SAMESITE=lax

# ===== Rate limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
